# Back4App Environment Configuration
# Copy this file to .env and fill in your actual values

# Back4App Configuration
BACK4APP_APP_ID=your-app-id-here
BACK4APP_JAVASCRIPT_KEY=your-javascript-key-here
BACK4APP_MASTER_KEY=your-master-key-here
BACK4APP_SERVER_URL=https://parseapi.back4app.com/

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Security Configuration
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here
CSRF_SECRET=your-csrf-secret-here
SESSION_SECRET=your-session-secret-here

# Rate Limiting
RATE_LIMIT_WINDOW=3600000
MAX_REQUESTS_PER_WINDOW=1000
BURST_LIMIT=100

# Caching
CACHE_TTL=300000
REDIS_URL=your-redis-url-here

# External APIs
BINANCE_API_URL=https://api.binance.com/api/v3
COINBASE_API_URL=https://api.exchange.coinbase.com
ALPHA_VANTAGE_API_URL=https://www.alphavantage.co/query

# Exchange Credentials (Store securely in Back4App Dashboard)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_SECRET_KEY=your-coinbase-secret-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
WAZIRX_API_KEY=your-wazirx-api-key
WAZIRX_SECRET_KEY=your-wazirx-secret-key
COINDCX_API_KEY=your-coindcx-api-key
COINDCX_SECRET_KEY=your-coindcx-secret-key

# Monitoring
HEALTH_CHECK_INTERVAL=30000
METRICS_RETENTION=30d

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Webhook URLs
WEBHOOK_URL=your-webhook-url-here

# Frontend Configuration
FRONTEND_URL=https://cryptopulse.b4a.app
ALLOWED_ORIGINS=https://cryptopulse.b4a.app,https://cryptopulse.app

# Database Configuration
MONGODB_URI=your-mongodb-uri-here

# Feature Flags
ENABLE_REAL_TRADING=false
ENABLE_RISK_ASSESSMENT=true
ENABLE_MARKET_ANALYSIS=true
ENABLE_NOTIFICATIONS=true

# Trading Configuration
DEFAULT_STRATEGY=conservative
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENTAGE=5
TAKE_PROFIT_PERCENTAGE=15

# Risk Management
MAX_DAILY_LOSS=1000
MAX_PORTFOLIO_RISK=0.2
VOLATILITY_THRESHOLD=0.3

# Logging
LOG_FORMAT=json
LOG_FILE=logs/app.log
MAX_LOG_SIZE=10m
MAX_LOG_FILES=5