# Back4App Environment Variables Configuration
# Copy this file to your Back4App dashboard and set the actual values

# Back4App Application Configuration
BACK4APP_APP_ID=your-back4app-app-id-here
BACK4APP_JAVASCRIPT_KEY=your-back4app-javascript-key-here
BACK4APP_MASTER_KEY=your-back4app-master-key-here
BACK4APP_SERVER_URL=https://parseapi.back4app.com/

# Application Configuration
NODE_ENV=production
PORT=3000

# Security Configuration
JWT_SECRET=your-jwt-secret-key-here
ENCRYPTION_KEY=your-32-character-encryption-key-here

# CORS Configuration
ALLOWED_ORIGINS=https://your-app.b4a.app,https://your-custom-domain.com

# Database Configuration (if using external database)
DATABASE_URL=your-database-connection-string-here

# External API Keys (if needed)
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_SECRET_KEY=your-binance-secret-key-here
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key-here

# Email Configuration (if using email services)
SMTP_HOST=your-smtp-host-here
SMTP_PORT=587
SMTP_USER=your-smtp-username-here
SMTP_PASS=your-smtp-password-here

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Session Configuration
SESSION_SECRET=your-session-secret-here
SESSION_TIMEOUT=3600000

# Feature Flags
ENABLE_TRADING=true
ENABLE_REAL_TRADING=false
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
