# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
APM_LOG_LEVEL=info
CACHE_TTL=300000
RATE_LIMIT_WINDOW=3600000
MAX_REQUESTS_PER_WINDOW=1000

# URLs for webhooks and redirects
