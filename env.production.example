# CryptoPulse Trading Bot - Production Environment
# Copy this file to .env and update with your actual values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
APP_NAME=CryptoPulse Trading Bot
VERSION=1.0.0
PORT=3000
BACKEND_PORT=8080

# =============================================================================
# BACK4APP CONFIGURATION
# =============================================================================
# Get these from your Back4App dashboard
VITE_BACK4APP_APP_ID=your-back4app-app-id
VITE_BACK4APP_CLIENT_KEY=your-back4app-client-key
VITE_BACK4APP_MASTER_KEY=your-back4app-master-key
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com/parse

# Backend Back4App config
APP_ID=your-back4app-app-id
JAVASCRIPT_KEY=your-back4app-client-key
MASTER_KEY=your-back4app-master-key
SERVER_URL=https://parseapi.back4app.com/parse

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB (for local development)
MONGO_USERNAME=cryptopulse
MONGO_PASSWORD=cryptopulse_mongo_2024
MONGO_DATABASE=cryptopulse
DATABASE_URL=mongodb://cryptopulse:cryptopulse_mongo_2024@mongodb:27017/cryptopulse

# Redis Cache
REDIS_URL=redis://:cryptopulse_redis_2024@redis:6379
REDIS_PASSWORD=cryptopulse_redis_2024

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate strong secrets for production
JWT_SECRET=your-super-secure-jwt-secret-here
ENCRYPTION_KEY=your-super-secure-encryption-key-here
SESSION_SECRET=your-super-secure-session-secret-here

# =============================================================================
# EXTERNAL API CONFIGURATION
# =============================================================================
# Binance API (for trading)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
VITE_BINANCE_API_URL=https://api.binance.com

# CoinGecko API (for market data)
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Cashfree Payment Gateway
VITE_CASHFREE_MODE=SANDBOX
VITE_CASHFREE_SANDBOX_APP_ID=your-cashfree-sandbox-app-id
VITE_CASHFREE_LIVE_APP_ID=your-cashfree-live-app-id

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
DEFAULT_PAIRS=BTC/USDT,ETH/USDT,ADA/USDT,BNB/USDT
DEFAULT_STRATEGY=AI_POWERED
RISK_LEVEL=MEDIUM
API_RATE_LIMIT=1000
API_WINDOW_MS=3600000

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
GRAFANA_PASSWORD=cryptopulse_grafana_2024
PROMETHEUS_RETENTION=200h

# =============================================================================
# UI CONFIGURATION
# =============================================================================
VITE_APP_NAME=CryptoPulse Trading Bot
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production
VITE_API_URL=https://parseapi.back4app.com/parse
VITE_API_TIMEOUT=30000
VITE_ENABLE_AI_AUTOMATION=true
VITE_ENABLE_LIVE_TRADING=false
VITE_ENABLE_BACKTESTING=true
VITE_ENABLE_ANALYTICS=true
VITE_LOG_LEVEL=info
VITE_ENABLE_CONSOLE_LOGS=false
VITE_CACHE_DURATION=300000
VITE_MAX_RETRY_ATTEMPTS=3
VITE_REQUEST_TIMEOUT=10000

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Docker Compose project name
COMPOSE_PROJECT_NAME=cryptopulse
COMPOSE_FILE=docker-compose.yml

# =============================================================================
# SSL CONFIGURATION (for production)
# =============================================================================
# Domain configuration for SSL certificates
DOMAIN_NAME=your-domain.com
SSL_EMAIL=admin@your-domain.com

# SSL certificate paths (automatically managed by Let's Encrypt)
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem

# Let's Encrypt configuration
LETSENCRYPT_EMAIL=admin@your-domain.com
LETSENCRYPT_STAGING=false
CERT_RENEWAL_THRESHOLD=30

# SSL security settings
SSL_PROTOCOLS=TLSv1.2,TLSv1.3
SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384
SSL_SESSION_CACHE=shared:SSL:10m
SSL_SESSION_TIMEOUT=10m

# Security headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
