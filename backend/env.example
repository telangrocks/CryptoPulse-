# Back4App Configuration
APP_ID=your-back4app-app-id
JAVASCRIPT_KEY=your-back4app-javascript-key
MASTER_KEY=your-back4app-master-key
SERVER_URL=https://parseapi.back4app.com/parse

# Application Configuration
NODE_ENV=production
PORT=8080
APP_NAME=CryptoPulse Trading Bot
VERSION=1.0.0

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/cryptopulse
REDIS_URL=redis://localhost:6379

# Trading Configuration
DEFAULT_PAIRS=BTC/USDT,ETH/USDT,ADA/USDT
DEFAULT_STRATEGY=AI_POWERED
RISK_LEVEL=MEDIUM

# API Configuration
API_RATE_LIMIT=1000
API_WINDOW_MS=3600000

# Security
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-encryption-key
SESSION_SECRET=your-session-secret

# External APIs
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_SECRET_KEY=your-coinbase-secret-key
