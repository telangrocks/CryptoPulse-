{
  "appName": "CryptoPulse",
  "description": "AI-Powered Cryptocurrency Trading Bot with Real-time Market Analysis",
  "version": "1.0.0",
  "parseVersion": "3.5.1",
  "cloudCode": {
    "main": "cloud/main.js",
    "functions": [
      "tradingBot",
      "marketAnalysis", 
      "userAuthentication",
      "portfolioManagement",
      "riskAssessment"
    ]
  },
  "webHosting": {
    "public": "frontend/dist",
    "index": "index.html",
    "spa": true,
    "buildCommand": "cd frontend && npm install && npm run build",
    "installCommand": "cd frontend && npm install"
  },
  "database": {
    "adapter": "mongo",
    "collections": [
      "User",
      "TradingBot", 
      "Portfolio",
      "Transaction",
      "MarketData",
      "TradingSignal"
    ]
  },
  "security": {
    "cors": {
      "origin": "*",
      "credentials": true
    },
    "rateLimit": {
      "requests": 1000,
      "window": 3600
    }
  },
  "features": {
    "cloudCode": true,
    "webHosting": true,
    "pushNotifications": true,
    "analytics": true,
    "fileStorage": true
  }
}
