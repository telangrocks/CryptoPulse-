# Production Environment Variables for CryptoPulse Frontend
# Copy this file to .env.production and fill in your actual values

# Back4App Configuration
VITE_BACK4APP_APP_ID=your-app-id-here
VITE_BACK4APP_CLIENT_KEY=your-javascript-key-here
VITE_BACK4APP_MASTER_KEY=your-master-key-here
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com/

# Application Configuration
VITE_APP_NAME=CryptoPulse
VITE_APP_VERSION=2.0.0
VITE_APP_ENVIRONMENT=production

# API Configuration
VITE_API_BASE_URL=https://parseapi.back4app.com/
VITE_WS_URL=wss://parseapi.back4app.com/

# Security Configuration
VITE_ENABLE_CSRF_PROTECTION=true
VITE_ENABLE_RATE_LIMITING=true
VITE_SESSION_TIMEOUT=86400000

# Feature Flags
VITE_ENABLE_REAL_TRADING=false
VITE_ENABLE_RISK_ASSESSMENT=true
VITE_ENABLE_MARKET_ANALYSIS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=true

# External APIs
VITE_BINANCE_API_URL=https://api.binance.com/api/v3
VITE_COINBASE_API_URL=https://api.exchange.coinbase.com

# Monitoring
VITE_ENABLE_ANALYTICS=true
VITE_LOG_LEVEL=warn

# Performance
VITE_ENABLE_CACHING=true
VITE_CACHE_TTL=300000
VITE_ENABLE_COMPRESSION=true

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_ANIMATION_ENABLED=true
VITE_LAZY_LOADING=true

# Trading Configuration
VITE_DEFAULT_STRATEGY=conservative
VITE_MAX_POSITION_SIZE=0.1
VITE_STOP_LOSS_PERCENTAGE=5
VITE_TAKE_PROFIT_PERCENTAGE=15

# Risk Management
VITE_MAX_DAILY_LOSS=1000
VITE_MAX_PORTFOLIO_RISK=0.2
VITE_VOLATILITY_THRESHOLD=0.3

# Cashfree Payment Gateway
VITE_CASHFREE_MODE=sandbox
VITE_CASHFREE_SANDBOX_APP_ID=your-sandbox-app-id
VITE_CASHFREE_LIVE_APP_ID=your-live-app-id
