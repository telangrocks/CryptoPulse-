# Back4App Configuration
VITE_BACK4APP_APP_ID=your-back4app-app-id
VITE_BACK4APP_CLIENT_KEY=your-back4app-client-key
VITE_BACK4APP_MASTER_KEY=your-back4app-master-key
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com/parse

# Application Configuration
VITE_APP_NAME=CryptoPulse Trading Bot
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production
VITE_API_URL=https://parseapi.back4app.com/parse
VITE_API_TIMEOUT=30000

# Trading Configuration
VITE_ENABLE_LIVE_TRADING=true
VITE_ENABLE_AI_AUTOMATION=true
VITE_ENABLE_BACKTESTING=true
VITE_ENABLE_ANALYTICS=true
VITE_DEFAULT_PAIRS=BTC/USDT,ETH/USDT,ADA/USDT,BNB/USDT
VITE_DEFAULT_STRATEGY=AI_POWERED
VITE_RISK_LEVEL=MEDIUM

# External API Configuration
VITE_BINANCE_API_URL=https://api.binance.com
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Payment Gateway Configuration
VITE_CASHFREE_MODE=SANDBOX
VITE_CASHFREE_SANDBOX_APP_ID=your-cashfree-sandbox-app-id
VITE_CASHFREE_LIVE_APP_ID=your-cashfree-live-app-id

# UI Configuration
VITE_THEME=dark
VITE_LANGUAGE=en
VITE_CURRENCY=USD
VITE_LOG_LEVEL=info
VITE_ENABLE_CONSOLE_LOGS=false
VITE_CACHE_DURATION=300000
VITE_MAX_RETRY_ATTEMPTS=3
VITE_REQUEST_TIMEOUT=10000

# Security Configuration
VITE_ENCRYPTION_KEY=your-super-secure-encryption-key-here
VITE_ENABLE_2FA=true
VITE_SESSION_TIMEOUT=3600

# SSL Configuration
VITE_SSL_ENABLED=true
VITE_FORCE_HTTPS=true