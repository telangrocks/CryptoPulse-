{
  "appName": "CryptoPulse",
  "description": "AI-Powered Cryptocurrency Trading Bot with Real-time Market Analysis",
  "version": "1.0.0",
  "parseVersion": "3.5.1",
  "cloudCode": {
    "main": "cloud/main.js",
    "functions": [
      "tradingBot",
      "marketAnalysis",
      "userAuthentication",
      "portfolioManagement",
      "riskAssessment",
      "getCurrentPrice",
      "getMarketData",
      "getTradingSignals",
      "getOrderHistory",
      "getPortfolioPerformance",
      "acceptDisclaimer",
      "getDisclaimerStatus",
      "getExchangeBalances",
      "executeRealTrade",
      "getExchangeOrderHistory",
      "healthCheck",
      "getSystemStatus"
    ]
  },
  "webHosting": {
    "public": "frontend/dist",
    "index": "index.html",
    "spa": true,
    "buildCommand": "cd frontend && node setup-env.cjs && npm run build:production",
    "installCommand": "cd frontend && npm install"
  },
  "database": {
    "adapter": "mongo",
    "collections": [
      "User",
      "TradingBot",
      "Portfolio",
      "Transaction",
      "MarketData",
      "TradingSignal"
    ]
  },
  "security": {
    "cors": {
      "origin": "*",
      "credentials": true
    },
    "rateLimit": {
      "requests": 1000,
      "window": 3600
    }
  },
  "features": {
    "cloudCode": true,
    "webHosting": true,
    "pushNotifications": true,
    "analytics": true,
    "fileStorage": true
  }
}