{
  "name": "cryptopulse-back4app",
  "version": "2.0.0",
  "description": "CryptoPulse Trading Bot - Production Ready Back4App Deployment",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "cd frontend && npm run build:production",
    "build:frontend": "cd frontend && npm ci && npm run build:production",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:coverage": "npm run test:backend -- --coverage && npm run test:frontend -- --coverage",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:fix": "npm run lint:backend -- --fix && npm run lint:frontend -- --fix",
    "deploy": "npm run build:frontend && npm run test && echo 'Ready for Back4App deployment'",
    "deploy:back4app": "npm run build:frontend && back4app deploy",
    "health": "node -e \"console.log('Health check passed')\"",
    "validate": "node scripts/validate-env.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "http-proxy-middleware": "^2.0.6",
    "parse": "^3.5.1",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.8",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "bot",
    "back4app",
    "parse",
    "production",
    "secure"
  ],
  "author": "Shrikant Telang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/telangrocks/CryptoPulse-"
  },
  "homepage": "https://cryptopulse.b4a.app"
}
