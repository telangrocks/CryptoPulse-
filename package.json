{
  "name": "cryptopulse-trading-bot",
  "version": "1.0.0",
  "description": "AI-Powered Cryptocurrency Trading Bot with Real-time Market Analysis",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd frontend && npm install && npm run build",
    "build:frontend": "cd frontend && npm install && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v --rmi all",
    "deploy": "chmod +x deploy.sh && ./deploy.sh",
    "health": "curl -f http://localhost:3000/health && curl -f http://localhost:8080/health",
    "doctor": "node doctor.js"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "bot",
    "ai",
    "blockchain",
    "crypto",
    "trading-bot",
    "automated-trading",
    "market-analysis"
  ],
